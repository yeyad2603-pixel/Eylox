# ── MongoDB ──────────────────────────────────────────────
# Local MongoDB (default — install from https://www.mongodb.com/try/download/community)
MONGO_URI=mongodb://127.0.0.1:27017/eylox

# MongoDB Atlas cloud (replace with your connection string when ready)
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/eylox

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=eylox_super_secret_key_change_in_production

# ── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development
